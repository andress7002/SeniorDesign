/*
 * main.c
 * Complete main code for your STM32 Thermal Reading Project (6 thermistors)
 * 
 * Hardware:
 * - 4 thermistors connected to ADS1115 (I2C, single-ended AIN0–AIN3)
 * - 2 thermistors directly connected to STM32 ADC pins
 * - Voltage divider for every thermistor: 3.3V — 10kΩ fixed resistor — Vout (to ADC) — NTC thermistor — GND
 * 
 * Features:
 * - Reads voltage from all 6 channels
 * - Converts voltage → resistance → temperature using Beta-parameter equation
 * - Prints temperatures every 1 second over UART (for debug in VS Code serial monitor)
 * - Fully self-contained (copy-paste into a CubeMX-generated project)
 * 
 * Requirements in STM32CubeMX / VS Code (PlatformIO or STM32CubeIDE):
 * 1. Enable I2C1 (or whichever I2C you use) in I2C mode
 * 2. Enable ADC1 in Regular mode, 12-bit resolution (at least 2 channels enabled)
 * 3. Enable UART (e.g. USART1 or USART2) for printf debug
 * 4. Generate code
 * 5. Paste this entire file over the default main.c (keep the generated MX_ functions)
 */

#include "main.h"
#include "stdio.h"
#include "math.h"

/* ==================== USER CONFIGURATION ==================== */
/* Change these values to match YOUR thermistors and hardware */

#define VREF                    3.3f          // Supply voltage for both ADC and voltage dividers
#define R_FIXED                 10000.0f      // Fixed resistor in voltage divider (10 kΩ typical)
#define R0                      10000.0f      // Thermistor resistance at 25 °C
#define BETA                    3950.0f       // Beta value of your NTC thermistor (common values: 3950, 3435, etc.)
#define T0                      298.15f       // 25 °C in Kelvin

/* ADS1115 settings */
#define ADS1115_I2C_ADDR        (0x48 << 1)  // Default I2C address (change if you use ADDR pin to select 0x49–0x4B)
#define ADS1115_PGA_FS          4.096f        // Full-scale voltage for the chosen PGA (±4.096 V is perfect for 3.3 V system)

/* Direct STM32 ADC channels (change to match the pins you wired) */
#define DIRECT_CH1              ADC_CHANNEL_0   // Example: PA0
#define DIRECT_CH2              ADC_CHANNEL_1   // Example: PA1
/* =========================================================== */

/* Global handles (auto-generated by CubeMX) */
extern I2C_HandleTypeDef hi2c1;      // Change to your I2C handle if different
extern ADC_HandleTypeDef hadc1;       // Change to your ADC handle if different
extern UART_HandleTypeDef huart2;     // Change to your UART handle if different (for printf)

/* ==================== HELPER FUNCTIONS ==================== */

/* Convert raw ADC reading (ADS1115) to voltage */
static float ADS1115_RawToVoltage(int16_t raw)
{
    return ((float)raw * ADS1115_PGA_FS) / 32768.0f;
}

/* Convert voltage to temperature (°C) using Beta equation */
static float VoltageToTemperature(float voltage)
{
    if (voltage <= 0.01f || voltage >= VREF - 0.01f)
        return -999.0f;                     // Invalid reading

    /* Calculate thermistor resistance */
    float r_therm = R_FIXED * voltage / (VREF - voltage);

    /* Steinhart-Hart simplified (Beta) */
    float temp_k = 1.0f / (1.0f / T0 + (1.0f / BETA) * logf(r_therm / R0));
    return temp_k - 273.15f;                // Return °C
}

/* ==================== ADS1115 DRIVER ==================== */

/* Write configuration and read one channel from ADS1115 */
static int16_t ADS1115_ReadChannel(uint8_t channel)
{
    uint8_t config[3];
    config[0] = 0x01;                       // Pointer register = Config register

    /* Config bytes (single-shot, 128 SPS, comparator disabled) */
    switch (channel)
    {
        case 0: config[1] = 0xC3; break;    // AIN0
        case 1: config[1] = 0xD3; break;    // AIN1
        case 2: config[1] = 0xE3; break;    // AIN2
        case 3: config[1] = 0xF3; break;    // AIN3
        default: return 0;
    }
    config[2] = 0x83;                       // 128 SPS, no comparator

    /* Write configuration */
    if (HAL_I2C_Master_Transmit(&hi2c1, ADS1115_I2C_ADDR, config, 3, 100) != HAL_OK)
        return 0;

    HAL_Delay(10);                          // Wait for conversion (≈8 ms at 128 SPS)

    /* Read conversion result */
    uint8_t reg = 0x00;                     // Pointer = Conversion register
    uint8_t data[2];
    if (HAL_I2C_Master_Transmit(&hi2c1, ADS1115_I2C_ADDR, &reg, 1, 100) != HAL_OK)
        return 0;
    if (HAL_I2C_Master_Receive(&hi2c1, ADS1115_I2C_ADDR, data, 2, 100) != HAL_OK)
        return 0;

    return (int16_t)((data[0] << 8) | data[1]);
}

/* ==================== DIRECT STM32 ADC HELPER ==================== */

/* Read one direct STM32 ADC channel and return voltage */
static float DirectADC_ReadVoltage(uint32_t channel)
{
    ADC_ChannelConfTypeDef sConfig = {0};

    sConfig.Channel      = channel;
    sConfig.Rank         = 1;
    sConfig.SamplingTime = ADC_SAMPLETIME_15CYCLES;   // Adjust if you changed it in CubeMX

    if (HAL_ADC_ConfigChannel(&hadc1, &sConfig) != HAL_OK)
        return 0.0f;

    if (HAL_ADC_Start(&hadc1) != HAL_OK)
        return 0.0f;

    if (HAL_ADC_PollForConversion(&hadc1, 100) != HAL_OK)
        return 0.0f;

    uint32_t raw = HAL_ADC_GetValue(&hadc1);
    HAL_ADC_Stop(&hadc1);

    return (raw * VREF) / 4095.0f;          // 12-bit ADC
}

/* ==================== MAIN ==================== */
int main(void)
{
    /* CubeMX generated initialization */
    HAL_Init();
    SystemClock_Config();      // Generated by CubeMX
    MX_GPIO_Init();
    MX_I2C1_Init();            // Your I2C
    MX_ADC1_Init();            // Your ADC
    MX_USART2_UART_Init();     // Your UART for printf (or change handle)

    /* Redirect printf to UART (optional but very useful) */
    setbuf(stdout, NULL);

    printf("\r\n=== STM32 6-Thermistor Thermal Reader Started ===\r\n\r\n");

    while (1)
    {
        float temps[6];

        /* === Read 4 channels from ADS1115 === */
        for (uint8_t i = 0; i < 4; i++)
        {
            int16_t raw = ADS1115_ReadChannel(i);
            float voltage = ADS1115_RawToVoltage(raw);
            temps[i] = VoltageToTemperature(voltage);
        }

        /* === Read 2 direct STM32 ADC channels === */
        float v5 = DirectADC_ReadVoltage(DIRECT_CH1);
        temps[4] = VoltageToTemperature(v5);

        float v6 = DirectADC_ReadVoltage(DIRECT_CH2);
        temps[5] = VoltageToTemperature(v6);

        /* === Print results (copy-paste friendly) === */
        printf("Thermistor Temperatures (°C):\r\n");
        printf("  ADS1115 AIN0: %6.2f\r\n", temps[0]);
        printf("  ADS1115 AIN1: %6.2f\r\n", temps[1]);
        printf("  ADS1115 AIN2: %6.2f\r\n", temps[2]);
        printf("  ADS1115 AIN3: %6.2f\r\n", temps[3]);
        printf("  Direct Ch1  : %6.2f\r\n", temps[4]);
        printf("  Direct Ch2  : %6.2f\r\n", temps[5]);
        printf("------------------------------------\r\n\r\n");

        HAL_Delay(1000);        // Update every 1 second (change as needed)
    }
}
